generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("student") // admin, staff, student
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile Student?
  staffProfile   StaffMember?
}

model Student {
  id             String             @id @default(uuid())
  userId         String             @unique
  user           User               @relation(fields: [userId], references: [id])
  level          Int                @default(1)
  gpa            Float              @default(0.0)
  departmentId   String?
  department     Department?        @relation(fields: [departmentId], references: [id])
  registrations  CourseRegistration[]
  excuseRequests ExcuseRequest[]
}

model StaffMember {
  id           String          @id @default(uuid())
  userId       String          @unique
  user         User            @relation(fields: [userId], references: [id])
  title        String          // e.g., Professor, Assistant Professor
  departmentId String
  department   Department      @relation(fields: [departmentId], references: [id])
  officeHours  String?
  papers       ResearchPaper[]
  courses      Course[]
}

model Department {
  id          String        @id @default(uuid())
  name        String
  description String
  headId      String?
  students    Student[]
  staff       StaffMember[]
  courses     Course[]
  programs    Program[]
}

model Program {
  id           String      @id @default(uuid())
  name         String
  type         String      // bachelor, master, phd
  description  String
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  requirements String
}

model Course {
  id            String               @id @default(uuid())
  code          String               @unique
  name          String
  creditHours   Int
  departmentId  String
  department    Department           @relation(fields: [departmentId], references: [id])
  instructorId  String?
  instructor    StaffMember?         @relation(fields: [instructorId], references: [id])
  registrations CourseRegistration[]
}

model CourseRegistration {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  grade     String?  // A, B, C... or null if ongoing
  semester  String
  year      Int
}

model News {
  id          String   @id @default(uuid())
  title       String
  content     String
  category    String
  imageUrl    String?
  publishedAt DateTime @default(now())
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String
}

model ResearchPaper {
  id          String      @id @default(uuid())
  title       String
  abstract    String
  authors     String
  staffId     String?
  staff       StaffMember? @relation(fields: [staffId], references: [id])
  publishedAt DateTime
  url         String?
}

model GraduationProject {
  id          String   @id @default(uuid())
  title       String
  description String
  team        String
  year        Int
}

model Gallery {
  id       String   @id @default(uuid())
  title    String
  imageUrl String
  category String
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model ExcuseRequest {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  reason    String
  status    String   @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now())
}
